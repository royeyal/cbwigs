{
  "name": "cbwigs-gsap-animations",
  "version": "1.0.0",
  "description": "GSAP animations for Webflow project",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler deploy",
    "lint": "eslint src --fix",
    "lint:css": "stylelint 'src/**/*.css' --fix",
    "format": "prettier --write 'src/**/*.{js,css}'",
    "prepare": "husky",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "autoprefixer": "^10.4.27",
    "cssnano": "^7.1.3",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "minimatch": "^10.2.4",
    "postcss": "^8.5.8",
    "postcss-nesting": "^14.0.0",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.46.0",
    "vite": "^7.3.1",
    "wrangler": "^4.71.0"
  },
  "dependencies": {
    "swiper": "^12.1.2"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "gsap",
    "animations",
    "webflow",
    "javascript",
    "css"
  ],
  "author": "",
  "license": "MIT"
}
